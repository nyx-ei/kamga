# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase browser-safe values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only values
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_EVIDENCE_BUCKET=evidences

# Cron
CRON_SECRET=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=Kamga <notifications@example.com>

# Security
# 32-byte hex string. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SIN_ENCRYPTION_KEY=

# Stripe
# Use sk_test... locally/preview and sk_live... only in production.
STRIPE_SECRET_KEY=
# From the Stripe webhook endpoint that targets /api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=

# Geocoding
# Use mapbox when MAPBOX_GEOCODING_TOKEN is configured; otherwise nominatim is used.
GEOCODING_PROVIDER=nominatim
MAPBOX_GEOCODING_TOKEN=
GEOCODING_USER_AGENT=Kamga/https://kamga.vercel.app

# Integrations reserved for upcoming tickets
SUPABASE_WEBHOOK_SECRET=
